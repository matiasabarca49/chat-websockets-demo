<link rel="stylesheet" href="./css/chat.css">
<div class="mainCont">

  <!-- ── Sidebar de chats ── -->
  <aside class="chatSidebar">
    <div class="chatSidebar__header">
      <span class="chatSidebar__logo">MSG</span>
    </div>

    <div class="chatSidebar__section">
      <span class="chatSidebar__label">Canales</span>
      <ul class="chatSidebar__list">
        <li class="chatSidebar__item chatSidebar__item--active" data-room="CHAT_GLOBAL_ID" id="sidebar-global">
          <span class="chatSidebar__hash">#</span>
          <span>Global</span>
          <span class="badge" id="conversation-CHAT_GLOBAL_ID" style="display: none;"></span>
        </li>
      </ul>
    </div>

    <div class="chatSidebar__section chatSidebar__section--grow">
      <div class="chatSidebar__labelRow">
        <span class="chatSidebar__label">Privados</span>
        <button class="chatSidebar__addBtn" id="btn-new-private" title="Nuevo chat privado">+</button>
      </div>

      <div class="chatSidebar__newChat" id="newChatForm" hidden>
        <input
          type="text"
          id="newChatInput"
          class="chatSidebar__newChatInput"
          placeholder="Usuario..."
          autocomplete="off"
        />
        <button class="chatSidebar__newChatConfirm" id="btn-confirm-private">→</button>
      </div>

      <ul class="chatSidebar__list" id="privateRoomsList"></ul>
    </div>

    <!-- Reutiliza currentUser ya existente en el footer -->
    <div class="chatSidebar__footer">
      <span class="chatSidebar__dot"></span>
      <span class="chatSidebar__footerName" id="currentUser"></span>
    </div>
  </aside>

  <!-- ── Área principal  ── -->
  <div class="containerPageChat">
    <div class="welcome">
      <h1 id="titleId">Bienvenido al chat</h1>
      <div class="welcome__user">
        <button class="btn-disconnect" id="btn-disconnect">Desconectarse →</button>
      </div>
    </div>

    <!-- connectedID intacto -->
    <div class="contUsers__othersUser">
      <div class="connectedStyle" id="connectedID"></div>
    </div>

    <div id="contChats" class="contChatsStyle">
      <div id="chatSpinner" class="spinner-wrapper" style="display: none;">
        <div class="loader"></div>
        <span>Cargando mensajes anteriores...</span>
      </div>

      {{!-- Acá van los mensajes --}}
      
      <span id="viewLastMsg"></span>
    </div>

    <form id="form">
      <div class="sendMessage">
        <input type="text" name="" id="text" placeholder="Escribe un mensaje" required>
        <button><img src="./img/send.png" alt=""></button>
      </div>
    </form>
  </div>

  <!-- Modal selección de usuario privado -->
    <div class="modalOverlay hidden" id="modalOverlay">
        <div class="modal">
            <div class="modal__header">
            <span class="modal__title">Nuevo chat privado</span>
            <button class="modal__close" id="modal__close">✕</button>
            </div>
            <div class="modal__body" id="modal__body">
            <!-- Se puebla dinámicamente -->
            </div>
        </div>
    </div>

</div>

<script src="./socket.io/socket.io.js"></script>
<script src="./index.js"></script>